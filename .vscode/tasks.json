{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-storm-harness",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"build",
				"storm-harness"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "replay-five-rows",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"run",
				"--rm",
				"-e",
				"DATA__BASE_PATH=/app/data/raw",
				"-e",
				"DATA__CRIME_FILE=Crimes_-_2001_to_Present_20260501.csv",
				"-e",
				"KAFKA__PRODUCER_RATE_PER_SECOND=0",
				"storm-harness",
				"python",
				"kafka/producer.py",
				"--config",
				"config/config.yaml",
				"--max-rows",
				"5"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "full-replay",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"run",
				"--rm",
				"-e",
				"DATA__BASE_PATH=/app/data/raw",
				"-e",
				"DATA__CRIME_FILE=Crimes_-_2001_to_Present_20260501.csv",
				"-e",
				"KAFKA__PRODUCER_RATE_PER_SECOND=0",
				"storm-harness",
				"python",
				"kafka/producer.py",
				"--config",
				"config/config.yaml"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "check-counts",
			"type": "shell",
			"command": "docker",
			"args": [
				"exec",
				"docker-postgres-1",
				"psql",
				"-U",
				"crime_user",
				"-d",
				"crime_analytics",
				"-c",
				"select 'alerts' as table_name, count(*) from alerts union all select 'realtime_district_counts', count(*) from realtime_district_counts;"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "check-counts-bash",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker exec docker-postgres-1 psql -U crime_user -d crime_analytics -c \"select 'alerts' as table_name, count(*) from alerts union all select 'realtime_district_counts', count(*) from realtime_district_counts;\""
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "storm-logs",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker compose -f docker/docker-compose.yml logs --no-color --tail 120 storm-supervisor storm-submit-java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "supervisor-errors",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker compose -f docker/docker-compose.yml logs --no-color --tail 200 storm-supervisor | grep -iE 'worker|error|exception|launch|slot|assign'"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "supervisor-filter",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"logs",
				"--no-color",
				"--tail",
				"200",
				"storm-supervisor"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "build-storm-submit",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"--profile",
				"java-submit",
				"build",
				"storm-submit-java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "resubmit-topology",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"--profile",
				"java-submit",
				"up",
				"-d",
				"--force-recreate",
				"storm-submit-java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "submit-logs",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"logs",
				"--no-color",
				"--tail",
				"120",
				"storm-submit-java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "kill-topology",
			"type": "shell",
			"command": "docker",
			"args": [
				"exec",
				"docker-storm-nimbus-1",
				"storm",
				"kill",
				"crime-alert-topology",
				"-w",
				"1"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "resubmit-topology-fixed",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"--profile",
				"java-submit",
				"up",
				"-d",
				"--force-recreate",
				"storm-submit-java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "submit-logs-after-resubmit",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"-f",
				"docker/docker-compose.yml",
				"logs",
				"--no-color",
				"--tail",
				"80",
				"storm-submit-java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "storm-list",
			"type": "shell",
			"command": "docker",
			"args": [
				"exec",
				"docker-storm-nimbus-1",
				"storm",
				"list"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}