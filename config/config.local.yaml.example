# Per-developer local config overrides
# Copy this file to `config/config.local.yaml` and change paths/credentials locally.

data:
  base_path: "/home/<your-username>/datasets/crime_analytics"
  crime_file: "Crimes_-_2001_to_Present_20260501.csv"

postgres:
  host: "localhost"
  port: 5432
  database: "crime_analytics"
  user: "local_user"
  password: "local_password"

mongodb:
  host: "localhost"
  port: 27017

# Optional local overrides for Kafka when running outside Docker
kafka:
  bootstrap_servers: "localhost:9092"
